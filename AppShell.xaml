<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Tienda.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Tienda"
    Title="Bienvenida">

    <TabBar>

        <ShellContent Title="Bienvenida" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        <ShellContent Title="Altas clientes" Route="altas" ContentTemplate="{DataTemplate local:Altas}"/>
        <ShellContent Title="Listado clientes" Route="consulta" ContentTemplate="{DataTemplate local:Consulta}"/>
        <ShellContent Title="Consulta individual" Route="consultaIndividual" ContentTemplate="{DataTemplate local:ConsultaIndividual}"/>
    </TabBar>
</Shell>
